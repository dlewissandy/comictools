    "/series/3e3fdb21-8f39-42ff-add7-6fbdda798a21/issue/77fb926f-d068-45da-a96f-c2e835876ebc/scene/a4ba2802-20c1-442e-8453-ee3e81d1d501/panel/9ec40f26-e42f-47cb-9c6c-ee9b4402232e": [
      {
        "name": "You",
        "text_html": "<p>\ud83e\uddf9 cleared the board \u2014 the table is bare (the print and script stay)</p>\n",
